# Supabase project credentials (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Storage bucket for uploaded media (created by supabase/schema.sql)
SUPABASE_STORAGE_BUCKET="media"

# Admin login is handled by Supabase Auth (the admin user lives in your
# Supabase project, not here). Do NOT store admin credentials in .env.
# To create the admin user once, pass them inline only when seeding:
#   ADMIN_EMAIL="you@mail.com" ADMIN_PASSWORD="strong-password" npm run db:seed
# (or create the user directly in the Supabase dashboard).
