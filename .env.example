# Supabase project credentials (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Storage bucket for uploaded media (created by supabase/schema.sql)
SUPABASE_STORAGE_BUCKET="media"

# Seed/admin login (created in Supabase Auth by the seed script)
ADMIN_EMAIL="admin@ridho.local"
ADMIN_PASSWORD="change-this-password"
